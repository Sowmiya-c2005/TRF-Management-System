# ── Database Configuration ─────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/trf_management
# For SQLite (development):
# DATABASE_URL=sqlite:///./trf_management.db

# ── Security & JWT ───────────────────────────────────────────────────────────────────
SECRET_KEY=your-super-secret-jwt-key-change-in-production-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480
REQUIRE_AUTH=false

# ── SMTP Email Configuration ─────────────────────────────────────────────────────────
# Leave empty to disable email notifications (development mode)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=noreply@trfportal.com

# ── CORS Configuration ───────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Storage Configuration ────────────────────────────────────────────────────────────
STORAGE_MODE=local
# STORAGE_MODE=sharepoint

# SharePoint Configuration (if STORAGE_MODE=sharepoint)
SHAREPOINT_SITE_URL=https://yourcompany.sharepoint.com/sites/trf
SHAREPOINT_CLIENT_ID=your-client-id
SHAREPOINT_CLIENT_SECRET=your-client-secret

# ── Application Settings ─────────────────────────────────────────────────────────────
APP_NAME=TRF Management System
APP_ENV=development
# APP_ENV=production

# ── File Upload Settings ────────────────────────────────────────────────────────────
MAX_FILE_SIZE_MB=50
ALLOWED_FILE_EXTENSIONS=.pdf,.doc,.docx,.xls,.xlsx,.dwg,.dxf,.png,.jpg,.jpeg

# ── Logging ─────────────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FILE=logs/app.log
